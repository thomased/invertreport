Package: invertreport
Type: Package
Title: INSTAR: Reporting of Invertebrate Welfare in Ecological and Evolutionary Research
Version: 0.1.0
Authors@R: c(
    person("Thomas E.", "White", email = "thomas.white@sydney.edu.au",
           role = c("aut", "cre"), comment = c(ORCID = "0000-0002-3976-1734")),
